    "@tanstack/react-query": "^5.90.20",
    "@tanstack/react-router": "^1.158.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.468.0",
    "motion": "^11.18.2",
    "react": "^19.0.0",
    "react-day-picker": "^9.13.2",
