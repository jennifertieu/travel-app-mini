{
  "name": "travel-app-client",
  "private": true,
  "scripts": {
    "dev": "concurrently \"pnpm --filter=travel-app-pretrip dev\" \"pnpm --filter=travel-app-itinerary dev\" \"pnpm --filter=travel-app-duringtrip dev\" \"pnpm --filter=travel-app-shell dev\"",
    "dev:shell": "pnpm --filter=travel-app-shell dev",
    "dev:pretrip": "pnpm --filter=travel-app-pretrip dev",
    "dev:itinerary": "pnpm --filter=travel-app-itinerary dev",
    "dev:duringtrip": "pnpm --filter=travel-app-duringtrip dev",
    "dev:browser": "pnpm dev & wait-on http://localhost:2000 && ./scripts/launch-chrome-beta.sh",
    "dev:browser:fresh": "pnpm dev & wait-on http://localhost:2000 && ./scripts/launch-chrome-beta.sh --fresh",
    "build": "pnpm --filter=travel-app-pretrip build && pnpm --filter=travel-app-itinerary build && pnpm --filter=travel-app-duringtrip build && pnpm --filter=travel-app-shell build",
    "build:zephyr": "USE_ZEPHYR=true pnpm build",
    "preview": "pnpm --filter=travel-app-shell preview",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write \"**/*.{ts,tsx}\""
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "concurrently": "^9.1.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "prettier": "^3.2.5",
    "wait-on": "^9.0.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "zephyr-rspack-plugin": "^0.1.10"
  }
}
